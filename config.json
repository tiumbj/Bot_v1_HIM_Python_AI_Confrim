{
  "_meta": {
    "config_version": "2.11.0",
    "last_updated": "2026-03-06",
    "changelog": [
      "Fix JSON validity (commissioning block + trailing commas).",
      "Add runtime services: api/dashboard/ai_confirm/risk_guard/analytics for production sidecars.",
      "SIDEWAY_SCALP: set touch_buffer_atr=0.10 (per prior changelog intent).",
      "Keep risk.atr_sl_mult=1.6 as source-of-truth.",
      "Tune gates to increase trade frequency (relax vol + ST conflict; lower min_rr)."
    ]
  },

  "api": {
    "host": "127.0.0.1",
    "port": 5000
  },

  "dashboard": {
    "host": "127.0.0.1",
    "port": 8502,
    "external_url": ""
  },

  "symbol": "GOLD",
  "mode": "breakout",

  "timeframes": {
    "htf": "H1",
    "mtf": "M15",
    "ltf": "M5"
  },

  "structure_sensitivity": {
    "htf": 5,
    "mtf": 4,
    "ltf": 3
  },

  "atr": {
    "period": 14,
    "sl_mult": 1.6
  },

  "risk": {
    "atr_period": 14,
    "atr_sl_mult": 1.6
  },

  "min_rr": 1.3,
  "decision_timeframes": ["M10", "M15", "M30", "H1"],
  "decision_min_agree": 2,
  "bos_break_atr_min": 0.12,
  "bos_lookback": 12,
  "st_relax_dist_atr_m1": 0.6,
  "bb_width_atr_min": 0.8,
  "bb_width_atr_min_m1": 0.55,
  "rr_sl_atr": 1.25,
  "rr_base_tp_atr": 1.9,

  "trend_entry": {
    "enabled": true,
    "min_align": 1,
    "max_supertrend_distance_atr": 2.6
  },

  "supertrend": {
    "period": 10,
    "mult": 3.0
  },

  "breakout": {
    "confirm_buffer_atr": 0.05,
    "proximity_threshold_atr": 2.5,
    "proximity_min_score": 10.0,
    "retest_required": true,
    "retest_band_atr": 0.3,
    "adx_proximity_override": 30.0,
    "dynamic_retest_bypass_adx": 35.0
  },

  "commissioning": {
    "enabled": true,
    "poll_sec": 1.0,
    "event_timeframes": [
      "M1"
    ],
    "events_log_path": "logs/commissioning_events.jsonl",
    "state_path": ".commission_event_state.json"
  },

  "continuation": {
    "enabled": false,
    "require_mtf_ltf_align": true,
    "require_htf_not_opposite": true,
    "proximity_threshold_atr": 1.8,
    "proximity_min_score": 20.0
  },

  "sideway_scalp": {
    "enabled": true,
    "adx_period": 14,
    "adx_max": 35.0,
    "bb_period": 20,
    "bb_std": 2.0,
    "bb_width_atr_max": 6.0,
    "rsi_period": 14,
    "rsi_overbought": 70.0,
    "rsi_oversold": 30.0,
    "touch_buffer_atr": 0.1,
    "near_trigger_atr": 0.9,
    "proximity_window_atr": 2.5,
    "rsi_soft_band": 25.0,
    "allow_soft_trigger": true,
    "require_confirmation": false,
    "proximity_score_min": 0.4
  },

  "profiles": {
    "sideway_scalp": {
      "mode": "sideway_scalp",
      "timeframes": {
        "htf": "H1",
        "mtf": "M15",
        "ltf": "M5"
      },
      "min_rr": 1.5,
      "risk": {
        "atr_period": 14,
        "atr_sl_mult": 1.6
      },
      "execution": {
        "enable_live_trading": true,
        "allow_multiple_positions": true,
        "duplicate_cooldown_sec": 30,
        "max_spread_points": 300,
        "max_deviation_points": 50,
        "volume": 0.01,
        "magic": 240227,
        "require_symbol_trade_allowed": true
      },
      "sideway_scalp": {
        "enabled": true,
        "adx_period": 14,
        "adx_max": 22.0,
        "bb_period": 20,
        "bb_std": 2.0,
        "bb_width_atr_max": 6.0,
        "rsi_period": 14,
        "rsi_overbought": 70.0,
        "rsi_oversold": 30.0,
        "require_confirmation": true,
        "touch_buffer_atr": 0.1
      }
    }
  },

  "telegram": {
    "enabled": true,
    "notify_on": ["signal", "trade", "error"],
    "token_env": "TELEGRAM_BOT_TOKEN_TRADE",
    "chat_id_env": "TELEGRAM_TRADE_CHAT_ID"
  },

  "ai": {
    "api_url": "http://127.0.0.1:5000/api/ai_confirm",
    "timeout_sec": 15,
    "min_rr": 1.5,
    "entry_shift_max_atr": 0.2,
    "entry_shift_max_pct": 0.0,
    "enforce_mode_lock": false
  },

  "ai_confirm": {
    "use_llm": true,
    "provider": "deepseek",
    "llm_api_url": "https://api.deepseek.com/v1/chat/completions",
    "llm_model": "deepseek-reasoner",
    "llm_timeout_sec": 8.0,
    "llm_max_tokens": 220,
    "llm_temperature": 0.1,
    "entry_shift_max_atr": 0.2,
    "external_url": "",
    "timeout_sec": 8.0,
    "min_confidence": null,
    "min_rr": 1.3
  },

  "risk_guard": {
    "initial_equity": 10000.0,
    "max_daily_dd_pct": 2.0,
    "max_total_dd_pct": 8.0,
    "poll_interval_sec": 5
  },

  "analytics": {
    "enabled": true,
    "interval_sec": 10,
    "output_path": "logs/performance_summary_live.json"
  },

  "proximity_score_min": 0.65,
  "confidence_threshold": 55,
  "min_score": 5,

  "lot": 0.01,
  "enable_execution": true
}
